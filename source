-- ============================================================
--  Feature 3: Auto-Teleport Through Safe Tiles (HRP)
-- ============================================================

local teleportRunning = false

makeButton(
    "Auto-Teleport Safe Tiles",
    "Teleport HRP through each safe tile",
    Color3.fromRGB(60, 180, 120),
    function()
        if teleportRunning then
            setStatus("Already running! Rejoin to stop.", Color3.fromRGB(255, 180, 60))
            return
        end

        local tilesFolder = getTilesFolder()
        if not tilesFolder then return end

        local character = player.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        if not hrp then
            setStatus("No HumanoidRootPart found.", Color3.fromRGB(255, 80, 80))
            return
        end

        local function findNextTile()
            for _, group in ipairs(tilesFolder:GetChildren()) do
                if group.Name == "Unactivated" and not group:FindFirstChild("Mine") then
                    return group
                end
            end
            return nil
        end

        local function getTileCFrame(group)
            if group:IsA("Model") and group.PrimaryPart then
                return group.PrimaryPart.CFrame
            end
            for _, part in ipairs(group:GetDescendants()) do
                if part:IsA("BasePart") then return part.CFrame end
            end
            return nil
        end

        teleportRunning = true
        setStatus("Teleporting...", Color3.fromRGB(60, 180, 120))

        task.spawn(function()
            local count = 0
            while true do
                local tile = findNextTile()
                if not tile then
                    setStatus(
                        string.format("Done! Visited %d tile(s).", count),
                        Color3.fromRGB(100, 220, 100)
                    )
                    teleportRunning = false
                    break
                end
                local cf = getTileCFrame(tile)
                if cf then
                    hrp.CFrame = cf + Vector3.new(0, 5, 0)
                    count = count + 1
                    setStatus(string.format("Teleporting... [%d]", count), Color3.fromRGB(60, 180, 120))
                end
                task.wait(0)
            end
        end)
    end
)

-- ============================================================
--  Feature 4: Count Safe vs Unsafe
-- ============================================================

makeButton(
    "Count Safe / Unsafe",
    "Print totals to Output without highlighting",
    Color3.fromRGB(200, 160, 40),
    function()
        local tilesFolder = getTilesFolder()
        if not tilesFolder then return end

        local safe, unsafe, total = 0, 0, 0
        for _, group in ipairs(tilesFolder:GetChildren()) do
            if group.Name == "Unactivated" then
                total = total + 1
                if group:FindFirstChild("Mine") then
                    unsafe = unsafe + 1
                else
                    safe = safe + 1
                end
            end
        end

        setStatus(
            string.format("Total: %d  |  Safe: %d  |  Unsafe: %d", total, safe, unsafe),
            Color3.fromRGB(200, 160, 40)
        )
        print(string.format("[Sloppy Tiles] Total: %d | Safe: %d | Unsafe: %d", total, safe, unsafe))
    end
)

