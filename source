local DiscordLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/UI-Libs/main/discord%20lib.txt"))()

local Players = game:GetService("Players")
local player = Players.LocalPlayer

local win = DiscordLib:Window("Sloppy Tiles")
local serv = win:Server("Main", "")

-- ============================================================
--  Helpers
-- ============================================================

local function getTilesFolder()
    return workspace:FindFirstChild("Tiles")
end

local function getTileCFrame(group)
    if group:IsA("Model") and group.PrimaryPart then
        return group.PrimaryPart.CFrame
    end
    for _, part in ipairs(group:GetDescendants()) do
        if part:IsA("BasePart") then return part.CFrame end
    end
    return nil
end

-- ============================================================
--  Channel: Scanner
-- ============================================================

local scanChannel = serv:Channel("Scanner")

scanChannel:Toggle("Highlight Unsafe Tiles", false, function(enabled)
    local tilesFolder = getTilesFolder()
    if not tilesFolder then
        DiscordLib:Notification("Error", "No 'Tiles' folder found in Workspace!", "Okay")
        return
    end

    if enabled then
        local count = 0
        for _, group in ipairs(tilesFolder:GetChildren()) do
            if group.Name == "Unactivated" and group:FindFirstChild("Mine") then
                if not group:FindFirstChild("SloppyHighlight") then
                    local highlight = Instance.new("SelectionBox")
                    highlight.Name = "SloppyHighlight"
                    highlight.Adornee = group
                    highlight.Color3 = Color3.fromRGB(255, 0, 0)
                    highlight.LineThickness = 0.05
                    highlight.SurfaceTransparency = 0.6
                    highlight.SurfaceColor3 = Color3.fromRGB(255, 0, 0)
                    highlight.Parent = group
                    count = count + 1
                end
            end
        end
        DiscordLib:Notification("Scanner", string.format("Highlighted %d unsafe tile(s).", count), "Got it")
    else
        local removed = 0
        for _, group in ipairs(tilesFolder:GetChildren()) do
            local h = group:FindFirstChild("SloppyHighlight")
            if h then
                h:Destroy()
                removed = removed + 1
            end
        end
        DiscordLib:Notification("Scanner", string.format("Removed %d highlight(s).", removed), "Got it")
    end
end)

scanChannel:Button("Count Safe / Unsafe", function()
    local tilesFolder = getTilesFolder()
    if not tilesFolder then
        DiscordLib:Notification("Error", "No 'Tiles' folder found in Workspace!", "Okay")
        return
    end

    local safe, unsafe = 0, 0
    for _, group in ipairs(tilesFolder:GetChildren()) do
        if group.Name == "Unactivated" then
            if group:FindFirstChild("Mine") then
                unsafe = unsafe + 1
            else
                safe = safe + 1
            end
        end
    end

    DiscordLib:Notification(
        "Tile Count",
        string.format("Safe: %d | Unsafe: %d | Total: %d", safe, unsafe, safe + unsafe),
        "Nice"
    )
    print(string.format("[Sloppy Tiles] Safe: %d | Unsafe: %d | Total: %d", safe, unsafe, safe + unsafe))
end)

-- ============================================================
--  Channel: Teleporter
-- ============================================================

local teleportChannel = serv:Channel("Teleporter")

local teleportRunning = false

teleportChannel:Button("Auto-Teleport Safe Tiles", function()
    if teleportRunning then
        DiscordLib:Notification("Teleporter", "Already running! Wait for it to finish.", "Okay")
        return
    end

    local tilesFolder = getTilesFolder()
    if not tilesFolder then
        DiscordLib:Notification("Error", "No 'Tiles' folder found in Workspace!", "Okay")
        return
    end

    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        DiscordLib:Notification("Error", "No HumanoidRootPart found. Are you in-game?", "Okay")
        return
    end

    local function findNextTile()
        for _, group in ipairs(tilesFolder:GetChildren()) do
            if group.Name == "Unactivated" and not group:FindFirstChild("Mine") then
                return group
            end
        end
        return nil
    end

    teleportRunning = true

    task.spawn(function()
        local count = 0
        while true do
            local tile = findNextTile()
            if not tile then
                DiscordLib:Notification(
                    "Teleporter",
                    string.format("Done! Visited %d safe tile(s).", count),
                    "Sweet"
                )
                teleportRunning = false
                break
            end
            local cf = getTileCFrame(tile)
            if cf then
                hrp.CFrame = cf + Vector3.new(0, 5, 0)
                count = count + 1
            end
            task.wait(0)
        end
    end)

    DiscordLib:Notification("Teleporter", "Started teleporting through safe tiles!", "Let's go")
end)

-- ============================================================
--  Channel: Entities
-- ============================================================

local entityChannel = serv:Channel("Entities")

-- Tracks connections so we can disconnect them when toggled off
local entityHighlightConnections = {}
local entityHighlightEnabled = false

local function highlightEntity(entity)
    -- Use a Highlight instance for the outline glow effect
    -- This works even on invisible parts since it renders a silhouette
    if entity:FindFirstChild("SloppyEntityHighlight") then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "SloppyEntityHighlight"
    highlight.Adornee = entity
    highlight.FillColor = Color3.fromRGB(255, 50, 50)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 0)
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0
    -- DepthMode = AlwaysOnTop so it shows through walls too
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = entity
end

local function removeEntityHighlight(entity)
    local h = entity:FindFirstChild("SloppyEntityHighlight")
    if h then h:Destroy() end
end

entityChannel:Toggle("Highlight Entities", false, function(enabled)
    local entitiesFolder = workspace:FindFirstChild("Entities")
    if not entitiesFolder then
        DiscordLib:Notification("Error", "No 'Entities' folder found in Workspace!", "Okay")
        return
    end

    -- Clean up previous connections no matter what
    for _, conn in ipairs(entityHighlightConnections) do
        conn:Disconnect()
    end
    entityHighlightConnections = {}
    entityHighlightEnabled = enabled

    if enabled then
        -- Highlight all current entities
        local count = 0
        for _, entity in ipairs(entitiesFolder:GetChildren()) do
            highlightEntity(entity)
            count = count + 1
        end

        -- Watch for new entities spawning in during the session
        local addedConn = entitiesFolder.ChildAdded:Connect(function(entity)
            if entityHighlightEnabled then
                highlightEntity(entity)
            end
        end)
        table.insert(entityHighlightConnections, addedConn)

        -- Watch for entities whose parts go invisible and force them visible
        -- by re-applying the highlight (Highlight instance ignores transparency)
        local descConn = entitiesFolder.DescendantAdded:Connect(function(desc)
            if entityHighlightEnabled and desc:IsA("BasePart") then
                local entity = desc:FindFirstAncestorOfClass("Model")
                if entity and entity.Parent == entitiesFolder then
                    highlightEntity(entity)
                end
            end
        end)
        table.insert(entityHighlightConnections, descConn)

        DiscordLib:Notification("Entities", string.format("Highlighting %d entity/entities.", count), "Got it")
    else
        -- Remove all highlights
        local removed = 0
        for _, entity in ipairs(entitiesFolder:GetChildren()) do
            removeEntityHighlight(entity)
            removed = removed + 1
        end
        DiscordLib:Notification("Entities", string.format("Removed highlights from %d entity/entities.", removed), "Got it")
    end
end)

entityChannel:Button("Count Entities", function()
    local entitiesFolder = workspace:FindFirstChild("Entities")
    if not entitiesFolder then
        DiscordLib:Notification("Error", "No 'Entities' folder found in Workspace!", "Okay")
        return
    end
    local count = #entitiesFolder:GetChildren()
    DiscordLib:Notification("Entities", string.format("%d entity/entities in folder.", count), "Okay")
    print(string.format("[Sloppy Tiles] Entities in folder: %d", count))
end)

