-- ============================================================
--  Button Factory
-- ============================================================

local function makeButton(label, desc, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 56)
    btn.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.Parent = scroll
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    -- Accent bar on left
    local accent = Instance.new("Frame")
    accent.Size = UDim2.new(0, 4, 1, -12)
    accent.Position = UDim2.new(0, 0, 0, 6)
    accent.BackgroundColor3 = color
    accent.BorderSizePixel = 0
    accent.Parent = btn
    Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 4)

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -18, 0, 22)
    title.Position = UDim2.new(0, 14, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = label
    title.TextColor3 = Color3.fromRGB(240, 240, 240)
    title.TextSize = 14
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = btn

    local sub = Instance.new("TextLabel")
    sub.Size = UDim2.new(1, -18, 0, 18)
    sub.Position = UDim2.new(0, 14, 0, 30)
    sub.BackgroundTransparency = 1
    sub.Text = desc
    sub.TextColor3 = Color3.fromRGB(120, 120, 120)
    sub.TextSize = 12
    sub.Font = Enum.Font.Gotham
    sub.TextXAlignment = Enum.TextXAlignment.Left
    sub.Parent = btn

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(38, 38, 38)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(28, 28, 28)}):Play()
    end)
    btn.MouseButton1Click:Connect(function()
        local ok, err = pcall(callback)
        if not ok then setStatus("Error: " .. tostring(err), Color3.fromRGB(255, 80, 80)) end
    end)

    return btn
end

-- ============================================================
--  Helper: get tiles folder
-- ============================================================

local function getTilesFolder()
    local f = workspace:FindFirstChild("Tiles")
    if not f then
        setStatus("No 'Tiles' folder in Workspace!", Color3.fromRGB(255, 80, 80))
        return nil
    end
    return f
end

-- ============================================================
--  Feature 1: Scan & Highlight Unsafe Tiles
-- ============================================================

local activeHighlights = {}

makeButton(
    "Scan & Highlight Unsafe",
    "Red highlight on tiles with a Mine child",
    Color3.fromRGB(220, 60, 60),
    function()
        -- Clear previous highlights
        for _, h in ipairs(activeHighlights) do
            if h and h.Parent then h:Destroy() end
        end
        activeHighlights = {}

        local tilesFolder = getTilesFolder()
        if not tilesFolder then return end

        local safe, unsafe = 0, 0

        for _, group in ipairs(tilesFolder:GetChildren()) do
            if group.Name == "Unactivated" then
                if group:FindFirstChild("Mine") then
                    local highlight = Instance.new("SelectionBox")
                    highlight.Adornee = group
                    highlight.Color3 = Color3.fromRGB(255, 0, 0)
                    highlight.LineThickness = 0.05
                    highlight.SurfaceTransparency = 0.6
                    highlight.SurfaceColor3 = Color3.fromRGB(255, 0, 0)
                    highlight.Parent = group
                    table.insert(activeHighlights, highlight)
                    unsafe = unsafe + 1
                else
                    safe = safe + 1
                end
            end
        end

        setStatus(
            string.format("Safe: %d  |  Unsafe: %d highlighted", safe, unsafe),
            Color3.fromRGB(100, 220, 100)
        )
    end
)

